# Default provider credentials.
# These are used only after the profile pool is exhausted or when no profile key exists.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
SUPABASE_DB_URL=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
QWEN_API_KEY=
QWEN_BASE_URL=
NVIDIA_NIM_API_KEY=
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com/api
OLLAMA_OPENAI_BASE_URL=https://ollama.com/v1
OLLAMA_LOCAL_BASE_URL=http://host.docker.internal:11434/api
OLLAMA_LOCAL_OPENAI_BASE_URL=http://host.docker.internal:11434/v1

# ANTS execution stack.
# Codex stays the preferred repository patch/test executor.
# Antigravity is an optional live-environment executor for terminal/browser work.
# Claude/Anthropic is an optional high-reasoning model provider.
CODEX_EXECUTOR_ENABLED=true
CODEX_AUTH_MODE=chatgpt
CODEX_CLI_PATH=codex
CODEX_HOME=
CODEX_WORKSPACE_ROOT=
CODEX_ALLOWED_ROOTS=
CODEX_REQUIRE_HARNESS=true
CODEX_USE_EXTERNAL_AUTH_STORE=true
CLAUDE_CODE_EXECUTOR_ENABLED=false
CLAUDE_CODE_AUTH_MODE=official_login_or_api_key
CLAUDE_CODE_CLI_PATH=claude
CLAUDE_CODE_WORKSPACE_ROOT=
CLAUDE_CODE_ALLOWED_ROOTS=
ANTIGRAVITY_EXECUTOR_ENABLED=false
ANTIGRAVITY_AUTH_MODE=official_cli_or_connector
ANTIGRAVITY_CLI_PATH=antigravity
ANTIGRAVITY_WORKSPACE_ROOT=
ANTIGRAVITY_REQUIRE_APPROVAL_FOR_SHELL=true
ANTIGRAVITY_REQUIRE_APPROVAL_FOR_BROWSER=true
ANTIGRAVITY_ALLOWED_ROOTS=
ANTS_TOOL_EXECUTION_MODE=guarded
ANTS_BLOCK_DESTRUCTIVE_COMMANDS=true
ANTS_REQUIRE_SPEC_FOR_TOOL_RUNS=true
ANTS_EXECUTOR_CREDENTIALS_MODE=encrypted_env
ANTS_EXECUTOR_CREDENTIALS_KEY=
ANTS_EXECUTOR_CREDENTIAL_POOL_ENC=

# Optional per-profile provider credentials.
# Pattern: PROVIDER__ACCOUNT_ID__API_KEY and PROVIDER__ACCOUNT_ID__BASE_URL.
# Keep profile IDs simple: 1, 2, 3, 4. When request.account_id is empty,
# ANTS tries profiles in ANTS_PROFILE_SEQUENCE order.
ANTS_PROFILE_SEQUENCE=1,2,3,4
OPENROUTER__DEFAULT__API_KEY=
OPENROUTER__1__API_KEY=
OPENROUTER__2__API_KEY=
OPENROUTER__3__API_KEY=
OPENROUTER__4__API_KEY=
QWEN__DEFAULT__API_KEY=
QWEN__DEFAULT__BASE_URL=https://token-plan.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
QWEN__1__API_KEY=
QWEN__1__BASE_URL=https://token-plan.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
QWEN__2__API_KEY=
QWEN__2__BASE_URL=https://token-plan.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
QWEN__3__API_KEY=
QWEN__3__BASE_URL=https://token-plan.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
QWEN__4__API_KEY=
QWEN__4__BASE_URL=https://token-plan.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
OLLAMA__DEFAULT__BASE_URL=http://host.docker.internal:11434
OLLAMA__1__API_KEY=
OLLAMA__1__BASE_URL=https://ollama.com/api
OLLAMA__2__API_KEY=
OLLAMA__2__BASE_URL=https://ollama.com/api
OLLAMA__3__API_KEY=
OLLAMA__3__BASE_URL=https://ollama.com/api
OLLAMA__4__API_KEY=
OLLAMA__4__BASE_URL=https://ollama.com/api
ANTHROPIC__DEFAULT__API_KEY=
ANTHROPIC__1__API_KEY=
ANTHROPIC__2__API_KEY=
ANTHROPIC__3__API_KEY=
ANTHROPIC__4__API_KEY=
OPENAI__DEFAULT__API_KEY=
OPENAI__1__API_KEY=
OPENAI__2__API_KEY=
OPENAI__3__API_KEY=
OPENAI__4__API_KEY=
GOOGLE__DEFAULT__API_KEY=
GOOGLE__1__API_KEY=
GOOGLE__2__API_KEY=
GOOGLE__3__API_KEY=
GOOGLE__4__API_KEY=
DEEPSEEK__DEFAULT__API_KEY=
DEEPSEEK__DEFAULT__BASE_URL=https://api.deepseek.com
DEEPSEEK__1__API_KEY=
DEEPSEEK__1__BASE_URL=https://api.deepseek.com
DEEPSEEK__2__API_KEY=
DEEPSEEK__2__BASE_URL=https://api.deepseek.com
DEEPSEEK__3__API_KEY=
DEEPSEEK__3__BASE_URL=https://api.deepseek.com
DEEPSEEK__4__API_KEY=
DEEPSEEK__4__BASE_URL=https://api.deepseek.com
KIMI__DEFAULT__API_KEY=
KIMI__DEFAULT__BASE_URL=https://api.moonshot.ai/v1
KIMI__1__API_KEY=
KIMI__1__BASE_URL=https://api.moonshot.ai/v1
KIMI__2__API_KEY=
KIMI__2__BASE_URL=https://api.moonshot.ai/v1
KIMI__3__API_KEY=
KIMI__3__BASE_URL=https://api.moonshot.ai/v1
KIMI__4__API_KEY=
KIMI__4__BASE_URL=https://api.moonshot.ai/v1
ANTS_ENV=local
ANTS_DEFAULT_PROVIDER=openrouter
ANTS_GATEWAY_PORT=8010
ANTS_SUPABASE_DOCKER_NETWORK=supabase_default
ANTS_GATEWAY_API_KEY=

# Optional GitHub repository provisioning.
# Use a fine-grained token with the minimum repository Administration write scope needed.
ANTS_GITHUB_TOKEN=
GITHUB_API_BASE_URL=https://api.github.com
